# ─── Database ────────────────────────────────────────────────────────────────
# ローカル開発 (SQLite, DB_SSL 不要)
DATABASE_URL=sqlite:///./study_manager.db
DB_SSL=false

# Neon 無料 PostgreSQL (https://neon.tech)
# DATABASE_URL=postgresql+pg8000://user:password@ep-xxx.region.aws.neon.tech/neondb
# DB_SSL=true

# Supabase 無料 PostgreSQL (https://supabase.com)
# DATABASE_URL=postgresql+pg8000://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
# DB_SSL=true

# ─── Google OAuth (空 = Dev Mode / 認証なし) ─────────────────────────────────
# https://console.cloud.google.com/apis/credentials  ← 無料
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ─── JWT ─────────────────────────────────────────────────────────────────────
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me

# ─── LINE (任意) ──────────────────────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=

# ─── Cron 保護キー ────────────────────────────────────────────────────────────
# 生成: python -c "import secrets; print(secrets.token_hex(16))"
CRON_SECRET=change-me

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=*
