# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./study_manager.db
DB_SSL=false

# Neon の場合
# DATABASE_URL=postgresql+pg8000://user:password@ep-xxx.region.aws.neon.tech/neondb
# DB_SSL=true

# ─── LINE Login（認証用チャンネル）────────────────────────────────────────────
# LINE Developers → LINE Loginチャンネル のChannel ID / Channel Secret
# 空のままにするとDev Mode（認証なし）で起動
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
LINE_LOGIN_REDIRECT_URI=http://localhost:8000/auth/callback

# ─── LINE Messaging API（通知用チャンネル）────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=
LINE_MESSAGING_CHANNEL_SECRET=   # Webhook署名検証用（Messaging APIチャンネルのSecret）

# ─── JWT ─────────────────────────────────────────────────────────────────────
# 生成: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me

# ─── Cron ────────────────────────────────────────────────────────────────────
CRON_SECRET=change-me
